---
layout: base.njk
title: Communities
---

<section class="content">
    <h1>Active Communities</h1>

    <p class="lead">NOTF supports {{ communities.length }} neighborhood-level initiatives across India, working on community-driven transformation.</p>

    <div class="stats-mini">
        <div class="stat-mini">
            <span class="number">{{ communities.length }}</span>
            <span class="label">Active Communities</span>
        </div>
        <div class="stat-mini">
            <span class="number">4</span>
            <span class="label">Cities</span>
        </div>
        <div class="stat-mini">
            <span class="number">{{ members.length }}</span>
            <span class="label">Partner Organizations</span>
        </div>
    </div>

    {% set bengaluruCommunities = communities | filterByCity('bengaluru') %}
    {% if bengaluruCommunities.length > 0 %}
    <h2>Bengaluru</h2>

    <div class="communities-grid">
    {% for community in bengaluruCommunities %}
        <div class="community-card">
            <h3>{{ community.name }}</h3>

            {% if community.neighborhood %}
                <p class="location">{{ community.neighborhood }}, {{ community.city | capitalize }}</p>
            {% endif %}

            {% if community.lead_organization %}
                <p class="lead-org">
                    <strong>Led by:</strong> {{ community.lead_organization | replace("organizations/", "") | replace("-", " ") | title }}
                </p>
            {% endif %}

            {% if community.focus_areas %}
                <p class="focus-areas">
                    <strong>Focus:</strong> {{ community.focus_areas | formatDomains }}
                </p>
            {% endif %}

            {% if community.population %}
                <p class="population">Population: {{ community.population }}</p>
            {% endif %}

            {% if community.status %}
                <p class="status">
                    <span class="status-badge status-{{ community.status }}">{{ community.status | capitalize }}</span>
                    {% if community.started %}since {{ community.started | formatDate }}{% endif %}
                </p>
            {% endif %}

            {% if community.contact %}
                <p class="contact-link">
                    <a href="mailto:{{ community.contact }}">Get in Touch &rarr;</a>
                </p>
            {% endif %}
        </div>
    {% endfor %}
    </div>
    {% endif %}

    <h2>Other Cities</h2>
    <p>We're expanding to communities in:</p>
    <ul>
        <li><strong>Mumbai</strong> - Coming soon</li>
        <li><strong>Ahmedabad</strong> - Coming soon</li>
        <li><strong>Bhubaneswar</strong> - Coming soon</li>
    </ul>

    <div class="cta-box">
        <h3>Start in Your Neighborhood</h3>
        <p>Interested in bringing NOTF to your neighborhood? Connect with us to explore possibilities.</p>
        <a href="mailto:nudge-unit@notf.in" class="btn btn-primary">Contact the Nudge Unit</a>
    </div>
</section>
