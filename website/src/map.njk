---
layout: base.njk
title: Community Map
permalink: /map/
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<section class="content map-page">
    <h1>NOTF Community Map</h1>
    <p class="lead">Explore {{ communities.length }} active neighborhoods across Bengaluru working on community-driven transformation.</p>
    
    <div class="map-controls">
        <div class="filter-group">
            <label>Filter by:</label>
            <button class="filter-btn active" data-filter="all">All Communities ({{ communities.length }})</button>
            <button class="filter-btn" data-filter="active">Active</button>
            <button class="filter-btn" data-filter="has-asks">With Asks</button>
            <button class="filter-btn" data-filter="has-offers">With Offers</button>
        </div>
        <button id="resetMap" class="reset-btn">Reset View</button>
    </div>
    
    <div id="map" class="community-map"></div>
    
    <div class="map-legend">
        <h3>Legend</h3>
        <div class="legend-items">
            <div class="legend-item">
                <span class="marker-icon active-marker"></span>
                <span>Active Community</span>
            </div>
            <div class="legend-item">
                <span class="marker-icon selected-marker"></span>
                <span>Selected</span>
            </div>
        </div>
    </div>
    
    <div class="community-list">
        <h2>All Communities</h2>
        <div class="community-cards-list" id="communityList">
            {% for community in communities %}
            <div class="community-list-card" data-slug="{{ community.slug }}">
                <h3>{{ community.name }}</h3>
                <p class="lead-org">{{ community.lead_organization_name }}</p>
                {% if community.ward %}
                <p class="location">Ward: {{ community.ward }}</p>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<script>
// Wait for Leaflet to load before initializing map
function initMap() {
    // Community data with coordinates
    const communities = {{ communities | dump | safe }};

    // Approximate coordinates for Bengaluru neighborhoods
    const neighborhoodCoords = {
    'jp-nagar': [12.9087, 77.5854],
    'kumara-park': [12.9933, 77.5758],
    'malleshwaram': [13.0067, 77.5703],
    'malleshwaram-2': [13.0070, 77.5710],
    'vasanthnagar': [12.9897, 77.6012],
    'sahakarnagar': [13.0834, 77.6227],
    'shanthinagar': [12.9698, 77.6012],
    'shanthinagar-2': [12.9705, 77.6020],
    'whitefield': [12.9698, 77.7499],
    'doddanekundi': [12.9899, 77.7145],
    'indiranagar': [12.9716, 77.6412],
    'kanakpura': [12.5432, 77.4176],
    'sanjaynagarrmv-ii-stage': [13.0240, 77.5794],
    'yelahanka': [13.1007, 77.5963],
    'hsr-layout': [12.9121, 77.6446],
    'doddakammanahalli-near-kottigerebannergatta': [12.8850, 77.6170],
    'shikaripalya-cluster': [12.9850, 77.7048],
    'sarjapura': [12.8080, 77.7860],
    'marappanapalya': [12.9167, 77.6333],
    'kasavanahalli': [12.9349, 77.6896],
    'kasavanahalli-2': [12.9355, 77.6900]
};

// Initialize map centered on Bengaluru
const map = L.map('map').setView([12.9716, 77.5946], 11);

// Add OpenStreetMap tiles
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors',
    maxZoom: 18
}).addTo(map);

// Custom icon
const defaultIcon = L.divIcon({
    className: 'custom-marker',
    html: '<div class="marker-pin"></div>',
    iconSize: [30, 42],
    iconAnchor: [15, 42],
    popupAnchor: [0, -42]
});

const selectedIcon = L.divIcon({
    className: 'custom-marker selected',
    html: '<div class="marker-pin selected"></div>',
    iconSize: [36, 50],
    iconAnchor: [18, 50],
    popupAnchor: [0, -50]
});

// Store markers
const markers = {};
let selectedMarker = null;

// Add markers for each community
communities.forEach(community => {
    const coords = neighborhoodCoords[community.slug];
    
    if (coords) {
        const marker = L.marker(coords, { icon: defaultIcon })
            .addTo(map);
        
        // Create popup content
        const popupContent = `
            <div class="map-popup">
                <h3>${community.name}</h3>
                <p class="popup-lead"><strong>Led by:</strong><br>${community.lead_organization_name}</p>
                ${community.ward ? `<p class="popup-ward">Ward: ${community.ward}</p>` : ''}
                ${community.contact && community.contact.person ? `<p class="popup-contact">Contact: ${community.contact.person}</p>` : ''}
                <a href="/notf/communities/" class="popup-link">View All Communities →</a>
            </div>
        `;
        
        marker.bindPopup(popupContent);
        
        // Store marker reference
        markers[community.slug] = marker;
        
        // Highlight on hover
        marker.on('click', function() {
            if (selectedMarker && selectedMarker !== marker) {
                selectedMarker.setIcon(defaultIcon);
            }
            marker.setIcon(selectedIcon);
            selectedMarker = marker;
            
            // Highlight in list
            document.querySelectorAll('.community-list-card').forEach(card => {
                card.classList.remove('highlighted');
            });
            const card = document.querySelector(`[data-slug="${community.slug}"]`);
            if (card) {
                card.classList.add('highlighted');
                card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        });
    }
});

// Filter functionality
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        // Update active state
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        
        const filter = this.dataset.filter;
        
        // Show/hide markers based on filter
        communities.forEach(community => {
            const marker = markers[community.slug];
            if (!marker) return;
            
            let show = true;
            
            if (filter === 'active') {
                show = community.status === 'active';
            } else if (filter === 'has-asks') {
                show = community.content && community.content.includes('Current Needs');
            } else if (filter === 'has-offers') {
                show = community.content && community.content.includes('What the Community Offers');
            }
            
            if (show) {
                marker.addTo(map);
            } else {
                marker.remove();
            }
        });
    });
});

// Reset map view
document.getElementById('resetMap').addEventListener('click', function() {
    map.setView([12.9716, 77.5946], 11);
    if (selectedMarker) {
        selectedMarker.setIcon(defaultIcon);
        selectedMarker = null;
    }
    document.querySelectorAll('.community-list-card').forEach(card => {
        card.classList.remove('highlighted');
    });
});

// Click on list card to highlight on map
document.querySelectorAll('.community-list-card').forEach(card => {
    card.addEventListener('click', function() {
        const slug = this.dataset.slug;
        const marker = markers[slug];
        
        if (marker) {
            // Pan to marker
            map.setView(marker.getLatLng(), 14);
            
            // Open popup
            marker.openPopup();
            
            // Update icon
            if (selectedMarker && selectedMarker !== marker) {
                selectedMarker.setIcon(defaultIcon);
            }
            marker.setIcon(selectedIcon);
            selectedMarker = marker;
            
            // Highlight card
            document.querySelectorAll('.community-list-card').forEach(c => {
                c.classList.remove('highlighted');
            });
            this.classList.add('highlighted');
        }
    });
});
}

// Check if Leaflet is loaded, if not wait for it
if (typeof L !== 'undefined') {
    initMap();
} else {
    // Wait for Leaflet script to load
    document.querySelector('script[src*="leaflet"]').addEventListener('load', initMap);
}
</script>
