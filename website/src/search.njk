---
layout: base.njk
title: Search
permalink: /search/
---

<section class="content search-page">
    <h1>Search NOTF Network</h1>
    
    <div class="search-container">
        <input 
            type="text" 
            id="searchInput" 
            class="search-input" 
            placeholder="Search communities, organizations, resources, asks, offers..."
            autocomplete="off"
        >
        <button id="clearSearch" class="clear-search" style="display: none;">✕</button>
    </div>
    
    <div class="search-stats">
        <p id="searchStats">Enter a search term to find communities, organizations, resources, and more</p>
    </div>
    
    <div class="search-results">
        <div id="communityResults" class="results-section" style="display: none;">
            <h2>Communities</h2>
            <div id="communityCards" class="communities-grid"></div>
        </div>
        
        <div id="organizationResults" class="results-section" style="display: none;">
            <h2>Organizations</h2>
            <div id="organizationCards" class="member-grid"></div>
        </div>
        
        <div id="askResults" class="results-section" style="display: none;">
            <h2>Community Asks</h2>
            <div id="askCards" class="ask-offer-grid"></div>
        </div>
        
        <div id="offerResults" class="results-section" style="display: none;">
            <h2>Community Offers</h2>
            <div id="offerCards" class="ask-offer-grid"></div>
        </div>
        
        <div id="resourceResults" class="results-section" style="display: none;">
            <h2>Resources</h2>
            <div id="resourceCards" class="resource-search-grid"></div>
        </div>
        
        <div id="noResults" class="no-results" style="display: none;">
            <p>No results found. Try different keywords.</p>
        </div>
    </div>
</section>

<script>
// Load all data
const communities = {{ communities | dump | safe }};
const members = {{ members | dump | safe }};

const searchInput = document.getElementById('searchInput');
const clearSearch = document.getElementById('clearSearch');
const searchStats = document.getElementById('searchStats');
const communityResults = document.getElementById('communityResults');
const organizationResults = document.getElementById('organizationResults');
const askResults = document.getElementById('askResults');
const offerResults = document.getElementById('offerResults');
const resourceResults = document.getElementById('resourceResults');
const noResults = document.getElementById('noResults');
const communityCards = document.getElementById('communityCards');
const organizationCards = document.getElementById('organizationCards');
const askCards = document.getElementById('askCards');
const offerCards = document.getElementById('offerCards');
const resourceCards = document.getElementById('resourceCards');

// Get search query from URL if present
const urlParams = new URLSearchParams(window.location.search);
const initialQuery = urlParams.get('q');
if (initialQuery) {
    searchInput.value = initialQuery;
    performSearch(initialQuery);
}

// Extract asks from all members and communities
function extractAsks() {
    const asks = [];
    
    // From organizations
    members.forEach(m => {
        if (m.asks && Array.isArray(m.asks)) {
            m.asks.forEach(ask => {
                asks.push({
                    text: ask,
                    from: m.name,
                    type: m.type || 'organization',
                    location: m.location,
                    contact: m.contact
                });
            });
        }
    });
    
    // From communities (via their lead orgs)
    communities.forEach(c => {
        if (c.content && c.content.includes('Current Needs')) {
            asks.push({
                text: 'Community needs identified',
                from: c.name,
                type: 'community',
                location: `${c.neighborhood}, ${c.city}`,
                leadOrg: c.lead_organization_name
            });
        }
    });
    
    return asks;
}

// Extract offers from all members
function extractOffers() {
    const offers = [];
    
    members.forEach(m => {
        if (m.offers && Array.isArray(m.offers)) {
            m.offers.forEach(offer => {
                offers.push({
                    text: offer,
                    from: m.name,
                    type: m.type || 'organization',
                    location: m.location,
                    contact: m.contact
                });
            });
        }
        
        // Infrastructure offers
        if (m.infrastructure_offers && Array.isArray(m.infrastructure_offers)) {
            m.infrastructure_offers.forEach(offer => {
                offers.push({
                    text: offer + ' (Infrastructure)',
                    from: m.name,
                    type: m.type || 'organization',
                    location: m.location,
                    contact: m.contact
                });
            });
        }
    });
    
    return offers;
}

// Create resource database (placeholder - you can populate this with real data)
function getResources() {
    return [
        {
            title: 'Community Organizing Playbook',
            type: 'playbook',
            description: 'Step-by-step guide for building strong neighborhood initiatives',
            topics: ['organizing', 'community', 'leadership', 'mobilization']
        },
        {
            title: 'Waste Management Toolkit',
            type: 'toolkit',
            description: 'Tools and templates for implementing community-led waste segregation',
            topics: ['waste', 'environment', 'sustainability', 'segregation']
        },
        {
            title: 'Malleshwaram Street Lighting Case Study',
            type: 'case-study',
            description: 'How Citizens for Citizens achieved zero dark spots through community action',
            topics: ['street lighting', 'safety', 'civic engagement', 'infrastructure']
        },
        {
            title: 'Urban Farming Toolkit',
            type: 'toolkit',
            description: 'Resources for starting rooftop gardens and urban agriculture',
            topics: ['farming', 'agriculture', 'rooftop', 'sustainability', 'food']
        },
        {
            title: 'Neighborhood Mapping Playbook',
            type: 'playbook',
            description: 'Guide to mapping community assets and needs',
            topics: ['mapping', 'assessment', 'planning', 'community']
        },
        {
            title: 'JP Nagar Waste Management Case Study',
            type: 'case-study',
            description: 'Women of Wisdom\'s success in community-led waste segregation',
            topics: ['waste', 'women', 'segregation', 'mobilization']
        }
    ];
}

// Search function
function performSearch(query) {
    const searchTerm = query.toLowerCase().trim();
    
    if (!searchTerm) {
        clearSearch.style.display = 'none';
        searchStats.textContent = 'Enter a search term to find communities, organizations, resources, and more';
        hideAllResults();
        return;
    }
    
    clearSearch.style.display = 'block';
    
    // Search communities
    const matchedCommunities = communities.filter(c => {
        return (
            (c.name && c.name.toLowerCase().includes(searchTerm)) ||
            (c.neighborhood && c.neighborhood.toLowerCase().includes(searchTerm)) ||
            (c.city && c.city.toLowerCase().includes(searchTerm)) ||
            (c.lead_organization_name && c.lead_organization_name.toLowerCase().includes(searchTerm)) ||
            (c.content && c.content.toLowerCase().includes(searchTerm)) ||
            (c.ward && c.ward.toLowerCase().includes(searchTerm))
        );
    });
    
    // Search organizations
    const matchedOrganizations = members.filter(m => {
        return (
            (m.name && m.name.toLowerCase().includes(searchTerm)) ||
            (m.type && m.type.toLowerCase().includes(searchTerm)) ||
            (m.description && m.description.toLowerCase().includes(searchTerm)) ||
            (m.location && m.location.toLowerCase().includes(searchTerm)) ||
            (m.theme && m.theme.toLowerCase().includes(searchTerm)) ||
            (m.neighborhoods && m.neighborhoods.some(n => n.toLowerCase().includes(searchTerm)))
        );
    });
    
    // Search asks
    const allAsks = extractAsks();
    const matchedAsks = allAsks.filter(ask => {
        return (
            (ask.text && ask.text.toLowerCase().includes(searchTerm)) ||
            (ask.from && ask.from.toLowerCase().includes(searchTerm)) ||
            (ask.location && ask.location.toLowerCase().includes(searchTerm))
        );
    });
    
    // Search offers
    const allOffers = extractOffers();
    const matchedOffers = allOffers.filter(offer => {
        return (
            (offer.text && offer.text.toLowerCase().includes(searchTerm)) ||
            (offer.from && offer.from.toLowerCase().includes(searchTerm)) ||
            (offer.location && offer.location.toLowerCase().includes(searchTerm))
        );
    });
    
    // Search resources
    const allResources = getResources();
    const matchedResources = allResources.filter(resource => {
        return (
            (resource.title && resource.title.toLowerCase().includes(searchTerm)) ||
            (resource.type && resource.type.toLowerCase().includes(searchTerm)) ||
            (resource.description && resource.description.toLowerCase().includes(searchTerm)) ||
            (resource.topics && resource.topics.some(t => t.toLowerCase().includes(searchTerm)))
        );
    });
    
    // Update stats
    const totalResults = matchedCommunities.length + matchedOrganizations.length + 
                        matchedAsks.length + matchedOffers.length + matchedResources.length;
    searchStats.textContent = `Found ${totalResults} result${totalResults !== 1 ? 's' : ''} for "${query}"`;
    
    // Display results
    if (totalResults === 0) {
        hideAllResults();
        noResults.style.display = 'block';
    } else {
        noResults.style.display = 'none';
        
        // Display communities
        if (matchedCommunities.length > 0) {
            communityResults.style.display = 'block';
            communityCards.innerHTML = matchedCommunities.map(c => `
                <div class="community-card">
                    <h3>${c.name}</h3>
                    ${c.ward ? `<p class="location">📍 Ward: ${c.ward}</p>` : ''}
                    <p class="lead-org"><strong>Led by:</strong> ${c.lead_organization_name}</p>
                    ${c.content ? `<div class="community-description">${c.content.substring(0, 150)}...</div>` : ''}
                    <a href="/notf/communities/" class="view-link">View All Communities →</a>
                </div>
            `).join('');
        } else {
            communityResults.style.display = 'none';
        }
        
        // Display organizations
        if (matchedOrganizations.length > 0) {
            organizationResults.style.display = 'block';
            organizationCards.innerHTML = matchedOrganizations.map(m => `
                <div class="member-card">
                    <h3>${m.name}</h3>
                    ${m.theme ? `<p class="theme">🎯 ${m.theme}</p>` : ''}
                    ${m.location ? `<p class="location">📍 ${m.location}</p>` : ''}
                    ${m.description ? `<p class="description">${m.description.substring(0, 150)}${m.description.length > 150 ? '...' : ''}</p>` : ''}
                    <a href="/notf/members/" class="view-link">View All Members →</a>
                </div>
            `).join('');
        } else {
            organizationResults.style.display = 'none';
        }
        
        // Display asks
        if (matchedAsks.length > 0) {
            askResults.style.display = 'block';
            askCards.innerHTML = matchedAsks.map(ask => `
                <div class="ask-offer-card ask-card">
                    <div class="card-header">
                        <span class="badge ask-badge">ASK</span>
                        <h4>${ask.from}</h4>
                    </div>
                    <p class="ask-offer-text">${ask.text}</p>
                    ${ask.location ? `<p class="location">📍 ${ask.location}</p>` : ''}
                    <span class="type-label">${ask.type}</span>
                </div>
            `).join('');
        } else {
            askResults.style.display = 'none';
        }
        
        // Display offers
        if (matchedOffers.length > 0) {
            offerResults.style.display = 'block';
            offerCards.innerHTML = matchedOffers.map(offer => `
                <div class="ask-offer-card offer-card">
                    <div class="card-header">
                        <span class="badge offer-badge">OFFER</span>
                        <h4>${offer.from}</h4>
                    </div>
                    <p class="ask-offer-text">${offer.text}</p>
                    ${offer.location ? `<p class="location">📍 ${offer.location}</p>` : ''}
                    <span class="type-label">${offer.type}</span>
                </div>
            `).join('');
        } else {
            offerResults.style.display = 'none';
        }
        
        // Display resources
        if (matchedResources.length > 0) {
            resourceResults.style.display = 'block';
            resourceCards.innerHTML = matchedResources.map(resource => `
                <div class="resource-search-card">
                    <div class="resource-type-badge ${resource.type}">${resource.type.replace('-', ' ')}</div>
                    <h3>${resource.title}</h3>
                    <p>${resource.description}</p>
                    <div class="resource-topics">
                        ${resource.topics.map(t => `<span class="topic-tag">${t}</span>`).join('')}
                    </div>
                    <a href="/notf/resources/" class="view-link">View Resources →</a>
                </div>
            `).join('');
        } else {
            resourceResults.style.display = 'none';
        }
    }
}

function hideAllResults() {
    communityResults.style.display = 'none';
    organizationResults.style.display = 'none';
    askResults.style.display = 'none';
    offerResults.style.display = 'none';
    resourceResults.style.display = 'none';
    noResults.style.display = 'none';
}

// Event listeners
searchInput.addEventListener('input', (e) => {
    performSearch(e.target.value);
});

searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
        performSearch(e.target.value);
    }
});

clearSearch.addEventListener('click', () => {
    searchInput.value = '';
    performSearch('');
    searchInput.focus();
});

// Focus search input on page load
searchInput.focus();
</script>
