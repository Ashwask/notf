---
layout: base.njk
title: Manage Communities - NOTF Admin
permalink: /admin/communities.html
---

<link rel="stylesheet" href="/assets/admin/admin.css">

<section class="admin-page">
    <div class="admin-container">
        <div class="page-header">
            <div>
                <h1>🏘️ Communities</h1>
                <p class="subtitle">Manage community organizations and groups</p>
            </div>
            <div class="header-actions">
                <a href="/admin/dashboard.html" class="btn-secondary">← Dashboard</a>
                <button onclick="showCreateForm()" class="btn-primary">➕ Add New</button>
                <button onclick="authUtils.logout()" class="btn-secondary">Logout</button>
            </div>
        </div>

        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="Search by name, city, or theme..." />
            <select id="statusFilter">
                <option value="all">All Status</option>
                <option value="active" selected>Active Only</option>
                <option value="pending">Pending Only</option>
            </select>
        </div>

        <div id="communitiesList" class="organizations-list">
            <p class="loading">Loading communities...</p>
        </div>

        <!-- Create/Edit Modal -->
        <div id="formModal" class="modal" style="display: none;">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Add Community</h2>
                    <button onclick="closeModal()" class="btn-close">×</button>
                </div>
                <form id="communityForm" class="organization-form">
                    <input type="hidden" id="commId" />
                    <input type="hidden" id="commFilePath" />

                    <div class="form-row">
                        <div class="form-group full">
                            <label for="commName">Community Name *</label>
                            <input type="text" id="commName" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="commCity">City *</label>
                            <input type="text" id="commCity" required placeholder="e.g., Bangalore, Mumbai" />
                        </div>
                        <div class="form-group">
                            <label for="commState">State</label>
                            <input type="text" id="commState" placeholder="e.g., Karnataka" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="commDescription">Description</label>
                        <textarea id="commDescription" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="commThemes">Themes (one per line)</label>
                        <textarea id="commThemes" rows="3" placeholder="Water&#10;Waste&#10;Energy"></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="commContactPerson">Contact Person</label>
                            <input type="text" id="commContactPerson" />
                        </div>
                        <div class="form-group">
                            <label for="commContactEmail">Email</label>
                            <input type="email" id="commContactEmail" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="commOffers">What They Offer (one per line)</label>
                        <textarea id="commOffers" rows="4" placeholder="Community space&#10;Local knowledge&#10;Volunteer network"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="commAsks">What They Need (one per line)</label>
                        <textarea id="commAsks" rows="4" placeholder="Technical expertise&#10;Funding&#10;Training programs"></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="commStatus">Status</label>
                            <select id="commStatus">
                                <option value="active">Active</option>
                                <option value="pending">Pending</option>
                                <option value="archived">Archived</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" onclick="closeModal()" class="btn-secondary">Cancel</button>
                        <button type="submit" class="btn-primary" id="submitBtn">
                            <span id="submitBtnText">Save</span>
                            <span id="submitBtnLoader" class="loader" style="display: none;">🔄</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/admin/auth.js"></script>
<script src="/assets/admin/communities.js"></script>
