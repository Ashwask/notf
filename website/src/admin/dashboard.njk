    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
}

.admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e0e0e0;
}

.admin-user {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.admin-user span {
    color: #666;
}

.admin-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
}

.stat-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.stat-icon {
    font-size: 2.5rem;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: bold;
    color: #333;
}

.stat-label {
    color: #666;
    font-size: 0.9rem;
}

.stat-link {
    color: #667eea;
    text-decoration: none;
    font-weight: 600;
    margin-top: auto;
}

.stat-link:hover {
    text-decoration: underline;
}

.admin-quick-actions {
    margin-bottom: 3rem;
}

.action-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
}

.action-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s, box-shadow 0.2s;
}

.action-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
}

.action-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

.action-title {
    font-weight: 600;
    color: #333;
    margin-bottom: 0.5rem;
}

.action-description {
    color: #666;
    font-size: 0.9rem;
}

.admin-recent {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.loading {
    text-align: center;
    color: #999;
    padding: 2rem;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/admin/auth.js"></script>
<script>
// Require authentication
(async function() {
    const session = await authUtils.requireAuth();
    if (!session) return;

    // Display user email
    const user = await authUtils.getCurrentUser();
    document.getElementById('userEmail').textContent = user.email;

    // Load stats
    await loadStats();
    await loadRecentActivity();
})();

async function loadStats() {
    const supabase = authUtils.supabase;

    // Count communities
    const { count: communityCount } = await supabase
        .from('file_metadata')
        .select('*', { count: 'exact', head: true })
        .eq('file_type', 'community')
        .eq('status', 'active');

    document.getElementById('communityCount').textContent = communityCount || 0;

    // Count solution providers
    const { count: providerCount } = await supabase
        .from('file_metadata')
        .select('*', { count: 'exact', head: true })
        .eq('file_type', 'solution-provider')
        .eq('status', 'active');

    document.getElementById('providerCount').textContent = providerCount || 0;

    // Count deployments (last 7 days)
    const sevenDaysAgo = new Date();
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

    const { count: deploymentCount } = await supabase
        .from('deployment_log')
        .select('*', { count: 'exact', head: true })
        .gte('created_at', sevenDaysAgo.toISOString());

    document.getElementById('deploymentCount').textContent = deploymentCount || 0;

    // Match count placeholder
    document.getElementById('matchCount').textContent = '—';
}

async function loadRecentActivity() {
    const supabase = authUtils.supabase;

    const { data, error } = await supabase
        .from('file_metadata')
        .select('*')
        .order('updated_at', { ascending: false })
        .limit(5);

    const container = document.getElementById('recentActivity');

    if (error || !data || data.length === 0) {
        container.innerHTML = '<p class="loading">No recent activity</p>';
        return;
    }

    container.innerHTML = `
        <table class="activity-table">
            <thead>
                <tr>
                    <th>Organization</th>
                    <th>Type</th>
                    <th>Last Updated</th>
                </tr>
            </thead>
            <tbody>
                ${data.map(item => `
                    <tr>
                        <td>${item.metadata?.name || item.slug}</td>
                        <td><span class="badge">${item.file_type}</span></td>
                        <td>${new Date(item.updated_at).toLocaleDateString()}</td>
                    </tr>
                `).join('')}
            </tbody>
        </table>
    `;
}

async function triggerDeploy() {
    if (!confirm('Trigger a manual deployment? This will rebuild the entire website.')) {
        return;
    }

    const VERCEL_DEPLOY_HOOK = 'https://api.vercel.com/v1/integrations/deploy/prj_9qpiHjvpGLQwIDA1O50lEG6dHpkM/4clSbfnJzy';

    try {
        const response = await fetch(VERCEL_DEPLOY_HOOK, { method: 'POST' });
        if (response.ok) {
            alert('✅ Deployment triggered successfully! Check Vercel dashboard for progress.');
        } else {
            alert('❌ Failed to trigger deployment');
        }
    } catch (error) {
        alert('❌ Error: ' + error.message);
    }
}
</script>

<style>
.activity-table {
    width: 100%;
    border-collapse: collapse;
}

.activity-table th {
    text-align: left;
    padding: 0.75rem;
    background: #f5f5f5;
    font-weight: 600;
}

.activity-table td {
    padding: 0.75rem;
    border-bottom: 1px solid #e0e0e0;
}

.badge {
    background: #667eea;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.85rem;
}
</style>
