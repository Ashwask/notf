<link rel="stylesheet" href="/assets/admin/admin.css">

<section class="admin-dashboard">
    <div class="admin-header">
        <h1>📊 Admin Dashboard</h1>
        <div class="admin-user">
            <span id="userEmail">Loading...</span>
            <button onclick="authUtils.logout()" class="btn-secondary">Logout</button>
        </div>
    </div>

    <div class="admin-stats">
        <div class="stat-card">
            <div class="stat-icon">🏘️</div>
            <div class="stat-content">
                <div class="stat-number" id="communityCount">-</div>
                <div class="stat-label">Communities</div>
            </div>
            <a href="/admin/communities.html" class="stat-link">Manage →</a>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🏢</div>
            <div class="stat-content">
                <div class="stat-number" id="providerCount">-</div>
                <div class="stat-label">Solution Providers</div>
            </div>
            <a href="/admin/organizations.html" class="stat-link">Manage →</a>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🤝</div>
            <div class="stat-content">
                <div class="stat-number" id="matchCount">-</div>
                <div class="stat-label">Potential Matches</div>
            </div>
            <a href="/admin/matcher.html" class="stat-link">View Matcher →</a>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🚀</div>
            <div class="stat-content">
                <div class="stat-number" id="deploymentCount">-</div>
                <div class="stat-label">Recent Deployments</div>
            </div>
        </div>
    </div>

    <div class="admin-quick-actions">
        <h2>Quick Actions</h2>
        <div class="action-grid">
            <a href="/admin/organizations.html?action=new" class="action-card">
                <div class="action-icon">➕</div>
                <div class="action-title">Add Solution Provider</div>
                <div class="action-description">Create a new organization entry</div>
            </a>

            <a href="/admin/communities.html?action=new" class="action-card">
                <div class="action-icon">🏘️</div>
                <div class="action-title">Add Community</div>
                <div class="action-description">Register a new community</div>
            </a>

            <a href="/admin/matcher.html" class="action-card">
                <div class="action-icon">🔍</div>
                <div class="action-title">View Matches</div>
                <div class="action-description">See ask/offer matches</div>
            </a>

            <a href="#" onclick="triggerDeploy(); return false;" class="action-card">
                <div class="action-icon">🔄</div>
                <div class="action-title">Trigger Deployment</div>
                <div class="action-description">Rebuild the website</div>
            </a>
        </div>
    </div>

    <div class="admin-recent">
        <h2>Recent Activity</h2>
        <div id="recentActivity">
            <p class="loading">Loading recent changes...</p>
        </div>
    </div>
</section>

<style>
