---
layout: base.njk
title: Manage Organizations - NOTF Admin
permalink: /admin/organizations.html
---

<link rel="stylesheet" href="/assets/admin/admin.css">

<section class="admin-page">
    <div class="admin-container">
        <div class="page-header">
            <div>
                <h1>🏢 Solution Providers</h1>
                <p class="subtitle">Manage organizations providing expertise and services</p>
            </div>
            <div class="header-actions">
                <a href="/admin/dashboard.html" class="btn-secondary">← Dashboard</a>
                <button onclick="showCreateForm()" class="btn-primary">➕ Add New</button>
                <button onclick="authUtils.logout()" class="btn-secondary">Logout</button>
            </div>
        </div>

        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="Search by name, city, or theme..." />
            <select id="statusFilter">
                <option value="all">All Status</option>
                <option value="active" selected>Active Only</option>
                <option value="pending">Pending Only</option>
            </select>
        </div>

        <div id="organizationsList" class="organizations-list">
            <p class="loading">Loading organizations...</p>
        </div>

        <!-- Create/Edit Modal -->
        <div id="formModal" class="modal" style="display: none;">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Add Solution Provider</h2>
                    <button onclick="closeModal()" class="btn-close">×</button>
                </div>
                <form id="organizationForm" class="organization-form">
                    <input type="hidden" id="orgId" />
                    <input type="hidden" id="orgFilePath" />

                    <div class="form-row">
                        <div class="form-group full">
                            <label for="orgName">Organization Name *</label>
                            <input type="text" id="orgName" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="orgTheme">Theme/Sector</label>
                            <input type="text" id="orgTheme" placeholder="e.g., Water, Waste, Energy" />
                        </div>
                        <div class="form-group">
                            <label for="orgLocation">Location</label>
                            <input type="text" id="orgLocation" placeholder="City, State" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="orgDescription">Description</label>
                        <textarea id="orgDescription" rows="3"></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="orgContactPerson">Contact Person</label>
                            <input type="text" id="orgContactPerson" />
                        </div>
                        <div class="form-group">
                            <label for="orgContactEmail">Email</label>
                            <input type="email" id="orgContactEmail" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="orgOffers">What They Offer (one per line)</label>
                        <textarea id="orgOffers" rows="4" placeholder="Expertise in waste management&#10;Training programs&#10;Consulting services"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="orgAsks">What They Need (one per line)</label>
                        <textarea id="orgAsks" rows="4" placeholder="Funding for programs&#10;Volunteers&#10;Partnership opportunities"></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="orgStatus">Status</label>
                            <select id="orgStatus">
                                <option value="active">Active</option>
                                <option value="pending">Pending</option>
                                <option value="archived">Archived</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" onclick="closeModal()" class="btn-secondary">Cancel</button>
                        <button type="submit" class="btn-primary" id="submitBtn">
                            <span id="submitBtnText">Save</span>
                            <span id="submitBtnLoader" class="loader" style="display: none;">🔄</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/admin/auth.js"></script>
<script src="/assets/admin/organizations.js"></script>
